<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:AvaloniaApplication2.ViewModels"
             x:Class="AvaloniaApplication2.Views.DirectionsView"
             x:DataType="vm:DirectionsViewModel"
             x:CompileBindings="False">
  <Grid RowDefinitions="Auto,*,Auto"
        RowSpacing="14">
    <Border Grid.Row="0"
            Padding="14"
            CornerRadius="12"
            Background="#FFF6F6F6"
            BorderBrush="#FFD9D9D9"
            BorderThickness="1">
      <Grid ColumnDefinitions="2.2*,Auto,Auto,Auto"
            ColumnSpacing="10">
        <TextBox Grid.Column="0"
                 Height="38"
                 Watermark="Поиск направления"
                 Text="{Binding SearchText}" />

        <Button Grid.Column="1"
                MinWidth="110"
                Height="38"
                Command="{Binding SearchCommand}"
                Content="Поиск" />

        <Button Grid.Column="2"
                MinWidth="150"
                Height="38"
                Command="{Binding ToggleSortCommand}"
                Content="Сортировка" />

        <Button Grid.Column="3"
                MinWidth="120"
                Height="38"
                Command="{Binding CreateNewCommand}"
                Content="Добавить" />
      </Grid>
    </Border>

    <Grid Grid.Row="1"
          ColumnDefinitions="2.3*,1.2*"
          ColumnSpacing="16">
      <Border Grid.Column="0"
              Padding="14"
              CornerRadius="12"
              Background="White"
              BorderBrush="#FFD9D9D9"
              BorderThickness="1">
        <Grid RowDefinitions="Auto,*,Auto"
              RowSpacing="12">
          <Grid Grid.Row="0"
                ColumnDefinitions="*,Auto"
                ColumnSpacing="10">
            <StackPanel Spacing="2">
              <TextBlock FontSize="20"
                         FontWeight="SemiBold"
                         Foreground="#FF202020"
                         Text="Список направлений" />
              <TextBlock FontSize="12"
                         Foreground="#FF6A6A6A"
                         Text="Постраничный вывод и сортировка по алфавиту." />
            </StackPanel>

            <Border Grid.Column="1"
                    Padding="10,6"
                    CornerRadius="10"
                    Background="#FFF7F7F7"
                    BorderBrush="#FFE1E1E1"
                    BorderThickness="1"
                    VerticalAlignment="Center">
              <TextBlock FontSize="12"
                         Foreground="#FF555555"
                         Text="{Binding TotalCount, StringFormat='Всего: {0}'}" />
            </Border>
          </Grid>

          <ListBox Grid.Row="1"
                   ItemsSource="{Binding Items}"
                   SelectedItem="{Binding SelectedItem}"
                   Background="Transparent"
                   BorderThickness="0">
            <ListBox.ItemTemplate>
              <DataTemplate>
                <Border Margin="0,0,0,12"
                        Padding="14"
                        CornerRadius="10"
                        Background="#FFFAFAFA"
                        BorderBrush="#FFE3E3E3"
                        BorderThickness="1">
                  <Grid ColumnDefinitions="112,*"
                        ColumnSpacing="14">
                    <Border Grid.Column="0"
                            Height="96"
                            CornerRadius="8"
                            Background="#FFF0F0F0"
                            BorderBrush="#FFD8D8D8"
                            BorderThickness="1">
                      <TextBlock HorizontalAlignment="Center"
                                 VerticalAlignment="Center"
                                 FontSize="14"
                                 Foreground="#FF707070"
                                 Text="Фото" />
                    </Border>

                    <Grid Grid.Column="1"
                          RowDefinitions="Auto,Auto,*,Auto"
                          RowSpacing="6">
                      <TextBlock FontSize="17"
                                 FontWeight="SemiBold"
                                 Foreground="#FF202020"
                                 Text="{Binding name}" />

                      <Border Grid.Row="1"
                              HorizontalAlignment="Left"
                              Padding="8,3"
                              CornerRadius="10"
                              Background="#FFF1F1F1">
                        <TextBlock FontSize="11"
                                   Foreground="#FF555555"
                                   Text="Направление каталога" />
                      </Border>

                      <TextBlock Grid.Row="2"
                                 TextWrapping="Wrap"
                                 MaxLines="3"
                                 Foreground="#FF4F4F4F"
                                 Text="{Binding description}" />

                      <TextBlock Grid.Row="3"
                                 HorizontalAlignment="Right"
                                 FontSize="11"
                                 Foreground="#FF777777"
                                 Text="{Binding lastModifiedAt, StringFormat='Изменено: {0:dd.MM.yyyy HH:mm}'}" />
                    </Grid>
                  </Grid>
                </Border>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>

          <Border Grid.Row="2"
                  Padding="10"
                  CornerRadius="10"
                  Background="#FFF7F7F7"
                  BorderBrush="#FFE1E1E1"
                  BorderThickness="1">
            <Grid ColumnDefinitions="Auto,Auto,*,Auto,Auto"
                  ColumnSpacing="10">
              <Button Grid.Column="0"
                      MinWidth="110"
                      Height="34"
                      Command="{Binding PreviousPageCommand}"
                      Content="Назад" />

              <Button Grid.Column="1"
                      MinWidth="110"
                      Height="34"
                      Command="{Binding NextPageCommand}"
                      Content="Вперёд" />

              <TextBlock Grid.Column="3"
                         VerticalAlignment="Center"
                         FontWeight="SemiBold"
                         Foreground="#FF303030"
                         Text="{Binding CurrentPage, StringFormat='Страница: {0}'}" />

              <TextBlock Grid.Column="4"
                         VerticalAlignment="Center"
                         Foreground="#FF666666"
                         Text="{Binding TotalPages, StringFormat='из {0}'}" />
            </Grid>
          </Border>
        </Grid>
      </Border>

      <Border Grid.Column="1"
              Padding="14"
              CornerRadius="12"
              Background="White"
              BorderBrush="#FFD9D9D9"
              BorderThickness="1">
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
          <StackPanel Spacing="10">
            <TextBlock FontSize="20"
                       FontWeight="SemiBold"
                       Foreground="#FF202020"
                       Text="Редактор направления" />

            <Border Padding="10"
                    CornerRadius="10"
                    Background="#FFF7F7F7"
                    BorderBrush="#FFE1E1E1"
                    BorderThickness="1">
              <StackPanel Spacing="4">
                <TextBlock FontSize="12"
                           Foreground="#FF666666"
                           Text="{Binding Id, StringFormat='ID: {0}'}" />
                <TextBlock FontSize="12"
                           Foreground="#FF666666"
                           Text="{Binding LastModifiedAt, StringFormat='Последнее изменение: {0:dd.MM.yyyy HH:mm}'}" />
              </StackPanel>
            </Border>

            <TextBlock FontWeight="SemiBold"
                       Foreground="#FF303030"
                       Text="Название" />
            <TextBox Text="{Binding Name}" />

            <TextBlock FontWeight="SemiBold"
                       Foreground="#FF303030"
                       Text="Описание" />
            <TextBox Height="180"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     VerticalContentAlignment="Top"
                     Text="{Binding Description}" />

            <Border Padding="10"
                    CornerRadius="10"
                    Background="#FFFCFCFC"
                    BorderBrush="#FFE8E8E8"
                    BorderThickness="1">
              <TextBlock TextWrapping="Wrap"
                         Foreground="#FF606060"
                         Text="{Binding StatusMessage}" />
            </Border>

            <Grid ColumnDefinitions="*,*"
                  ColumnSpacing="10"
                  Margin="0,6,0,0">
              <Button Grid.Column="0"
                      Height="38"
                      Background="#FF202020"
                      Foreground="White"
                      BorderBrush="#FF202020"
                      Command="{Binding SaveCommand}"
                      Content="Сохранить" />

              <Button Grid.Column="1"
                      Height="38"
                      Background="#FFF3F3F3"
                      Foreground="#FF202020"
                      BorderBrush="#FFD0D0D0"
                      Command="{Binding DeleteCommand}"
                      Content="Удалить" />
            </Grid>
          </StackPanel>
        </ScrollViewer>
      </Border>
    </Grid>

    <Border Grid.Row="2"
            Padding="12"
            CornerRadius="12"
            Background="#FFF6F6F6"
            BorderBrush="#FFD9D9D9"
            BorderThickness="1">
      <Grid ColumnDefinitions="*,Auto">
        <TextBlock VerticalAlignment="Center"
                   Foreground="#FF4F4F4F"
                   Text="{Binding StatusMessage}" />

        <TextBlock Grid.Column="1"
                   VerticalAlignment="Center"
                   FontWeight="SemiBold"
                   Foreground="#FF303030"
                   Text="{Binding TotalCount, StringFormat='Записей: {0}'}" />
      </Grid>
    </Border>
  </Grid>
</UserControl>
